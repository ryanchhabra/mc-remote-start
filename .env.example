# Discord OAuth app credentials
# Create an app at https://discord.com/developers/applications
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Auth.js session secret -- generate with: openssl rand -base64 32
AUTH_SECRET=

# Your site's URL (http://localhost:3000 for local dev)
AUTH_URL=http://localhost:3000

# Comma-separated Discord user IDs allowed to log in (right-click your
# profile in Discord with Developer Mode on to copy your ID)
ALLOWED_DISCORD_IDS=123456789012345678,234567890123456789

# Shared secret the Raspberry Pi agent uses to authenticate its requests.
# Must match the AGENT_API_KEY value set in pi_agent.py.
AGENT_API_KEY=replace-with-a-long-random-string
